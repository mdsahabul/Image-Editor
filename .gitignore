# --- Backend (Laravel) ---
backend/vendor/
backend/.env
backend/.env.backup
backend/storage/*.key
backend/storage/app/public/*
!backend/storage/app/public/.gitkeep
backend/storage/framework/cache/*
backend/storage/framework/sessions/*
backend/storage/framework/testing/*
backend/storage/framework/views/*
backend/storage/logs/*
!backend/storage/logs/.gitkeep
backend/bootstrap/cache/*.php
backend/public/storage
backend/.phpunit.result.cache
backend/Homestead.json
backend/Homestead.yaml
backend/npm-debug.log
backend/yarn-error.log

# --- Frontend (React) ---
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/.env
frontend/.env.local
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# --- AI service (Python) ---
ai-service/__pycache__/
ai-service/*.pyc
ai-service/venv/
ai-service/.venv/
ai-service/models/*.pth
ai-service/models/*.onnx
ai-service/models/*.bin

# --- OS / editor ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- Secrets (never commit) ---
*.pem
*.key
.env
.env.*
!.env.example
